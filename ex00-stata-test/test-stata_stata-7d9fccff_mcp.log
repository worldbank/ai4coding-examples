. * -------------------------------------------------------
. * 4. Figure 1 — Scatter with quadratic fitted lines by group
. * -------------------------------------------------------
. twoway     (scatter y x if group == 1, mcolor(navy%60)    msymbol(circle)   m
> size(small))     (scatter y x if group == 2, mcolor(maroon%60)  msymbol(squar
> e)   msize(small))     (scatter y x if group == 3, mcolor(forest_g%60) msymbo
> l(triangle) msize(small))     (qfit    y x if group == 1, lcolor(navy)    lwi
> dth(medthick))     (qfit    y x if group == 2, lcolor(maroon)  lwidth(medthic
> k))     (qfit    y x if group == 3, lcolor(forest_g) lwidth(medthick)),     l
> egend(order(1 "Group A" 2 "Group B" 3 "Group C")            rows(1) position(
